{
  "name": "finance-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Finance Tracker monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "frontend:dev": "pnpm --filter frontend dev",
    "backend:dev": "pnpm --filter backend start:dev",
    "db:generate": "pnpm --filter database prisma:generate",
    "db:migrate": "pnpm --filter database prisma:migrate",
    "db:seed": "pnpm --filter database prisma:seed",
    "db:reset": "pnpm --filter database prisma:reset",
    "db:studio": "pnpm --filter database prisma:studio",
    "bootstrap": "pnpm install && pnpm db:generate && pnpm build && pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0"
}
