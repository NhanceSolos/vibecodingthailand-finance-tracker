// Prisma schema for Personal Finance Tracker
// DATABASE_URL is loaded from the monorepo root .env via dotenv-cli in package.json scripts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionSource {
  WEB
  LINE
  RECURRING
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  lineUserId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  transactions Transaction[]
  categories   Category[]
  recurrings   Recurring[]
}

model Category {
  id        String          @id @default(cuid())
  name      String
  icon      String
  type      TransactionType
  // null = seed default ใช้ร่วมกันทุกคน, มีค่า = หมวดที่ user สร้างเอง
  userId    String?
  user      User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  transactions Transaction[]
  recurrings   Recurring[]

  // Compound unique lets seed re-run via upsert without duplicating defaults
  // and prevents a single user from creating two categories with the same (name, type).
  @@unique([name, type, userId])
  @@index([userId])
}

model Transaction {
  id          String            @id @default(cuid())
  amount      Decimal           @db.Decimal(12, 2)
  type        TransactionType
  description String?
  source      TransactionSource @default(WEB)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([categoryId])
}

model Recurring {
  id             String          @id @default(cuid())
  amount         Decimal         @db.Decimal(12, 2)
  type           TransactionType
  description    String
  dayOfMonth     Int
  active         Boolean         @default(true)
  lastExecutedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
